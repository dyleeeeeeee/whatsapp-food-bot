{
  "name": "whatsapp-food-bot",
  "version": "1.0.0",
  "description": "WhatsApp food ordering bot on Cloudflare Workers",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "node --test \"tests/**/*.test.mjs\"",
    "predeploy": "node --test \"tests/**/*.test.mjs\"",
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute food-bot-db --local --file=schema.sql",
    "db:migrate:prod": "wrangler d1 execute food-bot-db --file=schema.sql",
    "db:console:local": "wrangler d1 execute food-bot-db --local --command",
    "logs": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyleeeeeeee/whatsapp-food-bot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dyleeeeeeee/whatsapp-food-bot/issues"
  },
  "homepage": "https://github.com/dyleeeeeeee/whatsapp-food-bot#readme"
}
